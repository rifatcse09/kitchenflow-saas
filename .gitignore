# Dependencies (any depth, monorepo apps)
node_modules/
**/node_modules/

# Build outputs
dist/
build/
.next/
out/
*.tsbuildinfo

# Environment (keep *.example committed)
.env
.env.*
!.env.example

# Logs & debug
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Test / coverage
coverage/
.nyc_output/

# Caches
.cache/
.turbo/
*.local

# OS
.DS_Store
Thumbs.db

# Editors
.idea/
*.swp
*.swo
.vscode/*
!.vscode/extensions.json

# Optional: Bun (if you mix package managers)
# bun.lockb

# Optional: local DB / volumes (uncomment if you mount data next to the repo)
# postgres-data/
